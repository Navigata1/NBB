{
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(projects/Segment Mods/**)",
      "Write(.claude/skills/**)",
      "Write(docs/**)",
      "Write(research/**)",
      "Write(CHANGELOG.md)",
      "Write(SKILLS_REGISTRY.md)",
      "Write(HARD_STOPS.md)",
      "Write(HANDOFF.md)",
      "Write(packs/**)",
      "Write(bootstrap/**)",
      "Execute(git status)",
      "Execute(git diff **)",
      "Execute(git log *)",
      "Execute(bash scripts/*.sh)"
    ],
    "deny": [
      "Write(.env*)",
      "Execute(git push *)",
      "Execute(git push --force *)",
      "Execute(rm -rf *)",
      "Execute(git reset --hard *)",
      "Execute(git checkout -- *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/pre-write.sh" }
        ]
      }
    ]
  }
}
